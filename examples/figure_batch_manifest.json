{
  "format": "lmas-figure-batch-v0.1",
  "project_path": "synthetic_demo.lmas-project.yaml",
  "jobs": [
    {
      "output_path": "outputs/example_projection_dark.png",
      "theme": "dark",
      "color_by": "time",
      "maximum_chi2": 1.0,
      "show_panel_labels": true
    },
    {
      "output_path": "outputs/example_projection_portrait_light.png",
      "theme": "light",
      "color_by": "altitude",
      "layout": "xlma",
      "show_histogram": true,
      "show_panel_labels": true
    },
    {
      "output_path": "outputs/example_charge_colored.png",
      "theme": "dark",
      "color_by": "charge",
      "maximum_chi2": 1.0,
      "show_panel_labels": true
    }
  ],
  "dpi": 300,
  "dynamic_titles": true,
  "custom_title": "",
  "overwrite_policy": "replace",
  "continue_on_error": true,
  "cancel_file": null
}
